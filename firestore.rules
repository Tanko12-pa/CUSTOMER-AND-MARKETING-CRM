rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // TEMPORARY TESTING ONLY (Allows anyone to read/write for development)
    match /{document=**} {
      allow read, write: if true;
    }
    
    /* 
    PRODUCTION RECOMMENDED: Only allow authenticated users
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    */
  }
}
